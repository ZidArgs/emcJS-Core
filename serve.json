{
    "public": "./",
    "cleanUrls": false,
    "rewrites": [
        {
            "source": "/src/**",
            "destination": "/out/"
        },
        {
            "source": "/emcJS/**",
            "destination": "/out/"
        },
        {
            "source": "/",
            "destination": "/webtest/index.html"
        },
        {
            "source": "/:file",
            "destination": "/webtest/:file"
        },
        {
            "source": "/docs/:name/:file",
            "destination": "/webtest/docs/:name/:file"
        },
        {
            "source": "/home/:file",
            "destination": "/webtest/home/:file"
        }
    ]
}