{
    "type": "Fieldset",
    "label": "slider",
    "children": [
        {
            "type": "SliderInput",
            "label": "slider default",
            "name": "slider.default"
        },
        {
            "type": "SliderInput",
            "label": "slider gradations",
            "name": "slider.gradations",
            "min": "-10",
            "max": "30",
            "gradations": true
        },
        {
            "type": "SliderInput",
            "label": "slider resettable",
            "name": "slider.resettable",
            "min": "-20",
            "max": "20",
            "controlButtons": [
                "reset"
            ]
        },
        {
            "type": "SliderInput",
            "label": "slider disabled",
            "name": "slider.disabled",
            "min": "-10",
            "max": "30",
            "disabled": true
        }
    ]
}
