{
    "type": "Fieldset",
    "label": "password",
    "children": [
        {
            "type": "PasswordInput",
            "label": "password default",
            "name": "password.default",
            "placeholder": "Enter password..."
        },
        {
            "type": "PasswordInput",
            "label": "password resettable",
            "name": "password.resettable",
            "placeholder": "Enter password...",
            "controlButtons": [
                "reset"
            ]
        },
        {
            "type": "PasswordInput",
            "label": "password required",
            "name": "password.required",
            "placeholder": "Enter password...",
            "required": true
        },
        {
            "type": "PasswordInput",
            "label": "password readonly",
            "name": "password.readonly",
            "placeholder": "Enter password...",
            "readOnly": true
        },
        {
            "type": "PasswordInput",
            "label": "password disabled",
            "name": "password.disabled",
            "placeholder": "Enter password...",
            "disabled": true
        }
    ]
}
